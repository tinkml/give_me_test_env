# local | dev | prod — влияет на формат логов и теги Sentry/APM
ENVIRONMENT=local

# По переменной на каждую team — см. token_env в config/channels.yml
WEBHOOK_TOKEN_AKB=change-me

# Опционально: путь к YAML-конфигу команд, по умолчанию config/channels.yml
CHANNELS_CONFIG_PATH=config/channels.yml

POSTGRES_USER=stands_bot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stands_bot
POSTGRES_HOST=stands-bot-postgres
POSTGRES_PORT=5432

# Опционально: пусто — интеграция отключена
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Опционально: пусто — интеграция отключена
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SERVICE_NAME=stands-bot
