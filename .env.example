# local | dev | prod — влияет на формат логов и теги Sentry/APM
ENVIRONMENT=local

STANDS_BOT_WEBHOOK_TOKEN=change-me
STAND_NAMES=akb1,slplay4,slplay7,slplay8,slplay9

POSTGRES_USER=stands_bot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stands_bot
POSTGRES_HOST=stands-bot-postgres
POSTGRES_PORT=5432

# Опционально: пусто — интеграция отключена
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Опционально: пусто — интеграция отключена
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SERVICE_NAME=stands-bot
